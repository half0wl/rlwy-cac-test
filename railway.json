{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "runtime": "V2",
    "multiRegionConfig": {
      "us-west1": {
        "numReplicas": 1
      },
      "us-east4": {
        "numReplicas": 1
      }
    },
    "startCommand": "bun run index.ts"
  }
}
